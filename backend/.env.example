# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/astra_ai

# Security & JWT Configuration
SECRET_KEY=supersecretjwttokenkeyforastraai2026productionreadyjwt
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Configuration (Optional, fallback to simulations is supported)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Social Authentication (Optional)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# SMTP / Email Configuration for OTP Login (Fallback mock is supported)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password_here
OTP_EXPIRY_MINUTES=5
